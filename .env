# URL base do backend (web-ssiaas) que o app chama após o login Google.
#
# IMPORTANTE: no celular, "localhost" = o próprio celular, NÃO o seu PC.
# Use o IP da sua máquina alcançável pelo aparelho:
#   - IP da VPN (atual)            -> http://100.116.96.78:3000
#   - IP da LAN (mesma Wi-Fi)      -> http://192.168.x.x:3000
#   - USB com `adb reverse tcp:3000 tcp:3000` -> http://localhost:3000
#
# Variáveis EXPO_PUBLIC_* são embutidas no bundle no build/start do Metro.
# Para sobrescrever localmente sem versionar, use .env.local.
EXPO_PUBLIC_API_BASE_URL=http://100.116.96.78:3000
